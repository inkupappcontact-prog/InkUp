# Copiez ce fichier en .env et renseignez les valeurs.
# Ne commitez jamais le fichier .env (il est dans .gitignore).

# Client ID Google (OAuth 2.0) pour la connexion Google Sign-In.
# Obtenu depuis la console Firebase / Google Cloud (Credentials > Client ID type Web).
#
# Pour lancer l'app avec le client ID (sans le mettre dans le code) :
#   flutter run --dart-define=GOOGLE_CLIENT_ID=votre_client_id.apps.googleusercontent.com
#
# Exemple (à remplacer par votre valeur) :
# GOOGLE_CLIENT_ID=962346468274-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID=
