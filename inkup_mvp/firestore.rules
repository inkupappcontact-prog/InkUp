rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: lecture par le propriétaire; écriture limitée (inkPointsBalance, isPremiumAuthor mis à jour par Cloud Functions uniquement)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Series: lecture publique, écriture par l'auteur
    match /series/{seriesId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
    // Chapters: lecture publique, écriture par l'auteur de la série
    match /chapters/{chapterId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.seriesId != null;
    }
    // Products: lecture publique, écriture par l'auteur
    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
    // Orders: lecture par l'utilisateur concerné; création par l'utilisateur (détails validés côté Cloud Functions)
    match /orders/{orderId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    // Purchases/Unlocks: lecture par l'utilisateur; création par client ou Cloud Functions
    match /purchases/{purchaseId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    // Tips: lecture par l'émetteur ou le destinataire
    match /tips/{tipId} {
      allow read: if request.auth != null && (resource.data.fromUserId == request.auth.uid || resource.data.toAuthorId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
